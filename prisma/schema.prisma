// ==========================================
// 🏗️ المخطط الهندسي لقاعدة بيانات (Hyper Al-Wafa)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ==========================================
// 🏛️ جداول إمبراطورية (Hyper Al-Wafa)
// ==========================================

model Employee {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  name         String
  role         String
  roleArabic   String   // تأكد من وجوده هنا لأنه كان يسبب خطأ سابقاً
  jobTitle     String?
  branch       String?
  city         String?
  basicSalary  String?
  isActive     Boolean  @default(true)
  lastLogin    String?

  // 🔥 الأسطر السحرية التي ستحل مشكلة الـ Deploy الآن:
  attendances   Attendance[]
  leaves        Leave[]
  penalties     Penalty[]
  exitInterviews ExitInterview[]
}

// تأكد أن الموديلات الأخرى (Attendance, Leave...) 
// تشير إلى "Employee" بنفس الطريقة التي ظهرت في الخطأ

model Attendance {
  id          Int      @id @default(autoincrement())
  date        DateTime // التاريخ بصيغة صارمة
  code        String   // حالة التحضير (D, A, etc)
  timestamp   String
  note        String  
  // 🔗 الرابط مع الموظف
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Leave {
  id          Int      @id @default(autoincrement())
  type        String
  startDate   DateTime
  endDate     DateTime
  durration   String
  entryDate   DateTime
  // 🔗 الرابط مع الموظف
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Penalty {
  id             Int      @id @default(autoincrement())
  violationName  String
  category       String
  displayPenalty String
  managerName    String
  violationDate  DateTime
  managerComment String
  isAdmit        Boolean
  requestLessPunishment  Boolean
  actualOccurrence  Int
  appliedPenalty    String
  displayPenalty    String
  status            String
  attachment        String
  hrComment         String
  hrName            String
  timestamp         DateTime
  // 🔗 الرابط مع الموظف
  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
model ExitInterview {
  id                    Int      @id @default(autoincrement())
  interviewDate         DateTime @default(now())
  
  // 🔗 الرابط مع الموظف المغادر
  employeeId            Int
  employee              Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // 1. تفاصيل القرار
  decisionTime          String?
  reasons               String?
  
  // 2. الأحداث الخاصة
  specificEvent         Boolean  @default(false)
  eventDescription      String?
  discussedWithManager  Boolean  @default(false)
  discussionDetails     String?
  
  // 3. التقييمات (من 1 إلى 5)
  ratingTraining        Int?
  ratingManager         Int?
  ratingColleagues      Int?
  ratingSalary          Int?
  ratingBenefits        Int?
  ratingWorkload        Int?
  ratingSatisfaction    Int?
  
  // 4. المشاكل والإيجابيات
  encounteredProblems   Boolean  @default(false)
  problemsDescription   String?
  mostEnjoyed           String?
  leastEnjoyed          String?
  
  // 5. التوصيات المستقبلية
  wouldRecommend        Boolean  @default(true)
  recommendReason       String?
  wouldReapply          Boolean  @default(true)
  reapplyReason         String?
  
  additionalComments    String?
}
