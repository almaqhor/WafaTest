// ==========================================
// 🏗️ المخطط الهندسي لقاعدة بيانات (Hyper Al-Wafa)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ==========================================
// 🏛️ جداول إمبراطورية (Hyper Al-Wafa)
// ==========================================

model Employee {
  id          Int      @id @default(autoincrement()) // الرقم السري الخفي (لا يتغير أبداً)
  username    String   @unique                       // الرقم الوظيفي المؤقت أو الدائم
  password    String
  name        String
  role        String
  jobTitle    String?
  branch      String?
  basicSalary String?
  isActive    Boolean  @default(true)

  // 🔗 العلاقات الحديدية (الروابط مع الجداول الأخرى)
  attendances Attendance[]
  leaves      Leave[]
  penalties   Penalty[]
exitInterviews ExitInterview[]
}

model Attendance {
  id          Int      @id @default(autoincrement())
  date        DateTime // التاريخ بصيغة صارمة
  code        String   // حالة التحضير (D, A, etc)
  
  // 🔗 الرابط مع الموظف
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Leave {
  id          Int      @id @default(autoincrement())
  type        String
  startDate   DateTime
  endDate     DateTime
  
  // 🔗 الرابط مع الموظف
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Penalty {
  id             Int      @id @default(autoincrement())
  violationName  String
  category       String
  displayPenalty String
  
  // 🔗 الرابط مع الموظف
  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
model ExitInterview {
  id                    Int      @id @default(autoincrement())
  interviewDate         DateTime @default(now())
  
  // 🔗 الرابط مع الموظف المغادر
  employeeId            Int
  employee              Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // 1. تفاصيل القرار
  decisionTime          String?
  reasons               String?
  
  // 2. الأحداث الخاصة
  specificEvent         Boolean  @default(false)
  eventDescription      String?
  discussedWithManager  Boolean  @default(false)
  discussionDetails     String?
  
  // 3. التقييمات (من 1 إلى 5)
  ratingTraining        Int?
  ratingManager         Int?
  ratingColleagues      Int?
  ratingSalary          Int?
  ratingBenefits        Int?
  ratingWorkload        Int?
  ratingSatisfaction    Int?
  
  // 4. المشاكل والإيجابيات
  encounteredProblems   Boolean  @default(false)
  problemsDescription   String?
  mostEnjoyed           String?
  leastEnjoyed          String?
  
  // 5. التوصيات المستقبلية
  wouldRecommend        Boolean  @default(true)
  recommendReason       String?
  wouldReapply          Boolean  @default(true)
  reapplyReason         String?
  
  additionalComments    String?
}
