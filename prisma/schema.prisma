// ==========================================
// 🏗️ المخطط الهندسي لقاعدة بيانات (Hyper Al-Wafa)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ==========================================
// 🏛️ جداول إمبراطورية (Hyper Al-Wafa)
// ==========================================

model Employee {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  name               String
  password           String
  idNumber           String?  // الهوية
  idExpiry           String?  // انتهاء الهوية
  nationality        String?  // الجنسية
  gender             String?  // الجنس
  dobG               String?  // الميلاد ميلادي
  dobHijri           String?  // الميلاد هجري
  phone              String?  // الجوال
  email              String?  // الإيميل
  city               String?  // المدينة
  region             String?  // المنطقة
  splAddress         String?  // العنوان الوطني
  joinDate           String?  // تاريخ الالتحاق
  status             String?  // الحالة (in Duty, Resign...)
  isActive           Boolean  @default(true)
  branch             String?  // الفرع
  primarySection     String?  // القسم الرئيسي
  jobTitle           String?  // المسمى الوظيفي
  role               String?  // admin, user
  roleArabic         String?  // ادمن، موظف، مدير فرع
  directManager      String?  // المدير المباشر (مهم جداً لفريق العمل)
  workingDays        Int?     @default(6) // أيام العمل
  offDays            Int?     @default(1) // أيام الراحة
  lastWorkingDay     String?  // آخر يوم عمل
  basicSalary        String?  // الراتب الأساسي
  housingAllowance   String?  // بدل السكن
  otherAllowance     String?  // بدلات أخرى
  salaryE            String?  // إجمالي الراتب
  gosiFees           String?  // التأمينات
  bankName           String?  // اسم البنك
  bankIban           String?  // الآيبان
  leaveCredit        Float?   @default(0) // الرصيد المستحق
  usedLeaves         Float?   @default(0) // الإجازات المستخدمة
  leaveBalance       Float?   @default(0) // الرصيد المتبقي
  medicalIns         String?  // شركة التأمين
  insType            String?  // نوع التأمين
  insExpiry          String?  // انتهاء التأمين
  baladiyahCondition String?  // حالة البلدية
  baladiyahValid     String?  // صلاحية البلدية
  baladiyahFees      String?  // رسوم البلدية
  emergencyName      String?  // اسم الطوارئ
  emergencyNumber    String?  // رقم الطوارئ
  emergencyRelation  String?  // صلة القرابة
  lastLogin          String?  // آخر دخول
  policyConfirmed    Boolean  @default(false)
  currentMainShift   String?
  currentPeriod      String?
  
  // العلاقات (Relations)
  // العلاقات (تأكد أنها موجودة لكي لا ينهار الربط)
  attendances        Attendance[]
  leaves             Leave[]
  penalties          Penalty[]
  exitInterviews     ExitInterview[]
  requests           RequestTicket[]

  @@index([idNumber])
}

// تأكد أن الموديلات الأخرى (Attendance, Leave...) 
// تشير إلى "Employee" بنفس الطريقة التي ظهرت في الخطأ

model Attendance {
  id          Int      @id @default(autoincrement())
  date        DateTime // التاريخ بصيغة صارمة
  code        String   // حالة التحضير (D, A, etc)
  timestamp   DateTime
  note        String  
  // 🔗 الرابط مع الموظف
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Leave {
  id          Int      @id @default(autoincrement())
  type        String
  startDate   DateTime
  endDate     DateTime
  duration   Int
  enteryDate   DateTime
  returnDate  DateTime
  // 🔗 الرابط مع الموظف
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Penalty {
  id             Int      @id @default(autoincrement())
  violationName  String
  category       String
  displayPenalty String
  managerName    String
  violationDate  DateTime
  managerComment String
  isAdmit        Boolean
  requestLessPunishment  Boolean
  actualOccurrence  Int
  appliedPenalty    String
  status            String
  attachment        String
  hrComment         String
  hrName            String
  timestamp         DateTime
  // 🔗 الرابط مع الموظف
  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
model ExitInterview {
  id                    Int      @id @default(autoincrement())
  interviewDate         DateTime @default(now())
  
  // 🔗 الرابط مع الموظف المغادر
  employeeId            Int
  employee              Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // 1. تفاصيل القرار
  decisionTime          String?
  reasons               String?
  
  // 2. الأحداث الخاصة
  specificEvent         Boolean  @default(false)
  eventDescription      String?
  discussedWithManager  Boolean  @default(false)
  discussionDetails     String?
  
  // 3. التقييمات (من 1 إلى 5)
  ratingTraining        Int?
  ratingManager         Int?
  ratingColleagues      Int?
  ratingSalary          Int?
  ratingBenefits        Int?
  ratingWorkload        Int?
  ratingSatisfaction    Int?
  
  // 4. المشاكل والإيجابيات
  encounteredProblems   Boolean  @default(false)
  problemsDescription   String?
  mostEnjoyed           String?
  leastEnjoyed          String?
  
  // 5. التوصيات المستقبلية
  wouldRecommend        Boolean  @default(true)
  recommendReason       String?
  wouldReapply          Boolean  @default(true)
  reapplyReason         String?
  
  additionalComments    String?
}
model RequestTicket {
  id                      Int      @id @default(autoincrement()) // المفتاح التسلسلي (SQL يحب هذا)
  ticketId                String   @unique // رقم التذكرة الفعلي (مثل REQ-12345)
  employeeId              Int
  empUsername             String
  empName                 String?
  senderId                String?
  empPhone                String?
  managerName             String?
  hrSupervisor            String?
  assignedHrEmp           String?
  type                    String?
  details                 String?
  attachment              String?
  status                  String   @default("pending")
  createdAt               String?
  resolveDate             String?
  duration                String?
  managerComment          String?
  hrComment               String?
  supervisorAssignComment String?
  supervisorRejectComment String?
  escalationComment       String?
  empComment              String?
  rating                  String?
  resolvedBy              String?
  history                 String?

  employee                Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
// جدول التوظيف (جميع الحقول إجبارية - لا يوجد ?)
model Recruitment {
  id               Int      @id @default(autoincrement())
  candidateId      String   @unique 
  name             String
  idNumber         String   // إجباري
  dobG             String   // إجباري
  dobHijri         String   // إجباري
  phone            String   // إجباري
  email            String   // إجباري
  city             String   // إجباري
  jobTitle         String   // إجباري
  
  status           String   @default("pending")
  hrComment        String?  // (هذا فقط اختياري لأنه يضاف لاحقاً من الموارد)
  hrName           String?  // (وهذا أيضاً)
  cvFile           String?
  actionDate       DateTime?
  createdAt        DateTime @default(now())

  isFormerEmployee Boolean  @default(false)
}
model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique // مثلاً: 'BRANCH_TARGETS'
  value String // نخزن فيها الـ JSON كنص
}
