                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">الجنس</td><td style="padding:12px; font-weight:bold; color:#000;">${user.gender || '( ذكر / أنثى )'}</td>
                            </tr>
                            <tr style="border-bottom: 1px solid #eee;">
