                        التاريخ: ___ &nbsp;/&nbsp; ___ &nbsp;/&nbsp; _______ م
                    </div>
                `;
            }

            const pageHtml = `
                <div id="hr-form-print-area" style="width: 800px; height: 1131px; padding: 50px; font-family: 'Segoe UI', Tahoma, sans-serif; direction: rtl; background: white; color: #333; box-sizing: border-box; position: relative; overflow: hidden;">
                    ${headerHtml}
                    <h2 style="text-align:center; color:#333; margin-bottom: 40px; font-size:24px; text-decoration:underline;">${formTitle}</h2>
                    ${formContent}
                </div>
            `;

            tempContainer.innerHTML = pageHtml;
            document.body.appendChild(tempContainer);

            try {
                const canvasOpt = { scale: 2, useCORS: true, backgroundColor: '#ffffff', windowWidth: 800 };
                const canvas = await html2canvas(document.getElementById('hr-form-print-area'), canvasOpt);
                const link = document.createElement('a');
                link.download = `${fileName}.jpg`;
                link.href = canvas.toDataURL('image/jpeg', 0.95);
                link.click();

                document.body.removeChild(tempContainer);
                document.getElementById('print-forms-modal').style.display = 'none';
            } catch (error) {
                console.error("خطأ في توليد النموذج:", error);
                alert("حدث خطأ أثناء معالجة الصورة.");
                if(document.body.contains(tempContainer)) document.body.removeChild(tempContainer);
            }
            btn.innerHTML = `<i class="fas fa-file-image"></i> إصدار النموذج`; btn.disabled = false;
        }
        // ==================== بوابة الإجازات ====================
        let allLeavesData = [];

        // تحديث switchView لفتح البوابة وجلب البيانات
        const oldSwitchViewForLeaves = switchView;
        switchView = function(view) {
            oldSwitchViewForLeaves(view);
            // 🔥 السحر هنا: سمحنا للإدمن ولموظف الإدارة بجلب البيانات فور الدخول
            if(view === 'admin-leaves' && (globalIsAdmin || globalRoleArabic === 'موظف ادارة')) {
                loadLeavesData();
            }
        };

        async function loadLeavesData() {
            try {
                allLeavesData = await (await fetch('/api/leaves')).json();
                renderLeavesTable();
            } catch(e) { console.error("Error loading leaves", e); }
        }

        function fetchEmpNameForLeave() {
            const username = document.getElementById('lv-emp-id').value.trim();
            const user = allUsersData.find(u => u.username === username);
            document.getElementById('lv-emp-name').value = user ? user.name : 'غير موجود في النظام!';
        }

        function calcLeaveDates() {
            const startVal = document.getElementById('lv-start').value;
            const durVal = parseInt(document.getElementById('lv-duration').value);
            
            if(!startVal || isNaN(durVal) || durVal < 1) {
                document.getElementById('lv-end').value = '';
                document.getElementById('lv-return').value = '';
                return;
            }

            // حساب تاريخ الانتهاء (البداية + المدة - 1)
            let start = new Date(startVal);
            let end = new Date(start);
            end.setDate(end.getDate() + durVal - 1);
            
            // حساب تاريخ العودة (الانتهاء + 1)
            let returnDate = new Date(end);
            returnDate.setDate(returnDate.getDate() + 1);

            document.getElementById('lv-end').value = end.toISOString().split('T')[0];
            document.getElementById('lv-return').value = returnDate.toISOString().split('T')[0];
        }

        async function submitLeave() {
            const payload = {
                username: document.getElementById('lv-emp-id').value.trim(),
                type: document.getElementById('lv-type').value,
                startDate: document.getElementById('lv-start').value,
                duration: document.getElementById('lv-duration').value,
                endDate: document.getElementById('lv-end').value,
                returnDate: document.getElementById('lv-return').value,
                byUser: globalEmpName // 🔥 السطر الجديد لإرسال بصمة الموظف للسيرفر
            };

            if(!payload.username || !payload.startDate || !payload.duration || !document.getElementById('lv-emp-name').value) {
                return alert("يرجى التأكد من تعبئة جميع الحقول بشكل صحيح.");
            }

            if(confirm(`سيتم اعتماد إجازة للموظف وقفله في التحضير بـ (V) لمدة ${payload.duration} أيام. هل أنت متأكد؟`)) {
                await fetch('/api/leaves', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(payload) });
                alert("تم الاعتماد بنجاح! ✅");
                
                // تفريغ الحقول وتحديث الجدول
                document.getElementById('lv-emp-id').value = ''; document.getElementById('lv-emp-name').value = '';
                document.getElementById('lv-start').value = ''; document.getElementById('lv-duration').value = ''; calcLeaveDates();
                loadLeavesData();
            }
        }
        async function deleteLeave(id, empName) {
            if(!confirm(`⚠️ تحذير: هل أنت متأكد من حذف إجازة الموظف (${empName})؟\nهذا الإجراء سيقوم آلياً بـ:\n1. إرجاع أيام الإجازة في التحضير لتصبح (حاضر).\n2. إرجاع رصيد الإجازات المخصوم للموظف.`)) return;
            
            await fetch('/api/leave-delete', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id, byUser: globalEmpName})});
            alert('تم الحذف وإرجاع التحضير والرصيد بنجاح! 🗑️✅');
            loadLeavesData(); // جلب البيانات الجديدة
            loadAdminUsers(); // تحديث أرصدة الموظفين بالخلفية
        }

        function openEditLeave(id) {
            const l = allLeavesData.find(x => x.id === id);
            if(!l) return;
            document.getElementById('edit-lv-id').value = l.id;
            document.getElementById('edit-lv-type').value = l.type;
            document.getElementById('edit-lv-start').value = l.startDate;
            document.getElementById('edit-lv-duration').value = l.duration;
            document.getElementById('edit-lv-end').value = l.endDate;
            document.getElementById('edit-lv-return').value = l.returnDate;
            document.getElementById('edit-leave-modal').style.display = 'flex';
        }

        function calcEditLeaveDates() {
            const startVal = document.getElementById('edit-lv-start').value;
            const durVal = parseInt(document.getElementById('edit-lv-duration').value);
            if(!startVal || isNaN(durVal) || durVal < 1) return;
            let start = new Date(startVal);
            let end = new Date(start); end.setDate(end.getDate() + durVal - 1);
            let retDate = new Date(end); retDate.setDate(retDate.getDate() + 1);
            document.getElementById('edit-lv-end').value = end.toISOString().split('T')[0];
            document.getElementById('edit-lv-return').value = retDate.toISOString().split('T')[0];
        }

        async function submitEditLeave() {
            const payload = {
                id: document.getElementById('edit-lv-id').value,
                type: document.getElementById('edit-lv-type').value,
                startDate: document.getElementById('edit-lv-start').value,
                duration: document.getElementById('edit-lv-duration').value,
                endDate: document.getElementById('edit-lv-end').value,
                returnDate: document.getElementById('edit-lv-return').value,
                byUser: globalEmpName
            };
            if(confirm('تأكيد التعديل؟ سيقوم النظام آلياً بتسوية التحضير والرصيد بناءً على التواريخ الجديدة.')) {
                await fetch('/api/leave-edit', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)});
                alert('تم تعديل الإجازة وتحديث التحضير آلياً! 🔄✅');
                document.getElementById('edit-leave-modal').style.display = 'none';
                loadLeavesData();
                loadAdminUsers();
            }
        }

        function renderLeavesTable() {
            const searchTerm = document.getElementById('lv-search').value.toLowerCase().trim();
            const typeFilter = document.getElementById('lv-filter-type').value;
            
            let filtered = allLeavesData.filter(l => {
                const matchSearch = l.name.toLowerCase().includes(searchTerm) || l.username.toLowerCase().includes(searchTerm);
                const matchType = typeFilter === "" || l.type === typeFilter;
                return matchSearch && matchType;
            });

            filtered.sort((a, b) => new Date(b.startDate) - new Date(a.startDate)); // الأحدث أولاً

            // 🔥 السحر هنا: حساب مجموع الإجازات "السنوية" فقط بناءً على الفلتر الحالي
            let totalAnnual = 0;
            filtered.forEach(l => {
                if (l.type === 'سنوية') totalAnnual += parseInt(l.duration || 0);
            });

            // إظهار وإخفاء العداد بناءً على وجود بحث
            const summaryBadge = document.getElementById('lv-summary-badge');
            if (searchTerm !== "" || typeFilter === "سنوية") {
                summaryBadge.style.display = 'block';
                document.getElementById('lv-total-annual').innerText = totalAnnual;
            } else {
                summaryBadge.style.display = 'none';
            }

            const tbody = document.getElementById('leaves-table-body');
            
            const thead = tbody.previousElementSibling.querySelector('tr');
            if (!thead.innerHTML.includes('الإجراءات')) {
                thead.innerHTML += '<th>الإجراءات</th>';
            }

            if(filtered.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" style="text-align:center; color:#777;">لا توجد بيانات مطابقة</td></tr>';
                return;
            }

            tbody.innerHTML = filtered.map(l => `
                <tr>
                    <td style="font-weight:bold; color:#2980b9;">${l.username}</td>
                    <td>${l.name}</td>
                    <td><span style="background:#e8f8f5; color:#27ae60; padding:3px 8px; border-radius:12px; font-size:12px; font-weight:bold;">${l.type}</span></td>
                    <td>${l.startDate}</td>
                    <td style="font-weight:bold;">${l.duration} يوم</td>
                    <td style="color:#e74c3c; font-weight:bold;">${l.endDate}</td>
                    <td style="color:#27ae60; font-weight:bold;">${l.returnDate}</td>
                    <td style="font-size:11px; color:#777;">${l.entryDate}</td>
                    <td style="white-space:nowrap;">
                        ${l.type === 'سنوية' ? `<button style="background:#8e44ad; color:white; border:none; padding:5px 8px; border-radius:3px; cursor:pointer; margin-left:2px;" onclick="generateLeaveNotification('${l.id}')" title="إصدار نموذج إشعار إجازة (مادة 109)"><i class="fas fa-bell"></i></button>` : ''}
                        <button style="background:#f39c12; color:white; border:none; padding:5px 8px; border-radius:3px; cursor:pointer; margin-left:2px;" onclick="openEditLeave('${l.id}')" title="تعديل"><i class="fas fa-edit"></i></button>
                        <button style="background:#e74c3c; color:white; border:none; padding:5px 8px; border-radius:3px; cursor:pointer;" onclick="deleteLeave('${l.id}', '${l.name}')" title="حذف"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            `).join('');
        }
        // دالة توليد وطباعة برنت الإجازات
        function printLeaveReport() {
            const searchTerm = document.getElementById('lv-search').value.trim();
            const typeFilter = document.getElementById('lv-filter-type').value;
            
            let filtered = allLeavesData.filter(l => {
                const matchSearch = l.name.toLowerCase().includes(searchTerm.toLowerCase()) || l.username.toLowerCase().includes(searchTerm.toLowerCase());
                const matchType = typeFilter === "" || l.type === typeFilter;
                return matchSearch && matchType;
            });
            filtered.sort((a, b) => new Date(b.startDate) - new Date(a.startDate)); 

            if(filtered.length === 0) return alert("لا توجد بيانات لطباعتها!");

            let totalAnnual = filtered.reduce((sum, l) => l.type === 'سنوية' ? sum + parseInt(l.duration) : sum, 0);

            // فتح نافذة طباعة مجهزة بتصميم رسمي
            let printWindow = window.open('', '', 'width=900,height=700');
            
            let tableHtml = `
                <table style="width:100%; border-collapse: collapse; margin-top:20px; text-align:right;" border="1">
                    <thead style="background:#f4f4f4;">
                        <tr><th style="padding:10px;">الرقم الوظيفي</th><th style="padding:10px;">الاسم</th><th style="padding:10px;">النوع</th><th style="padding:10px;">البداية</th><th style="padding:10px;">المدة</th><th style="padding:10px;">العودة</th></tr>
                    </thead>
                    <tbody>
                        ${filtered.map(l => `<tr><td style="padding:8px;">${l.username}</td><td style="padding:8px;">${l.name}</td><td style="padding:8px; font-weight:bold;">${l.type}</td><td style="padding:8px;">${l.startDate}</td><td style="padding:8px;">${l.duration} يوم</td><td style="padding:8px;">${l.returnDate}</td></tr>`).join('')}
                    </tbody>
                </table>
            `;

            let html = `
                <html dir="rtl" lang="ar">
                <head>
                    <title>سجل إجازات موظف - هايبر الوفاء</title>
                    <style>body{font-family: 'Segoe UI', Tahoma, sans-serif; padding: 40px; color:#333;}</style>
                </head>
                <body>
                    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom: 3px solid #007f3d; padding-bottom: 15px; margin-bottom: 20px;">
                        <div>
                            <h1 style="margin:0; color:#007f3d; font-size: 28px; font-weight:900; letter-spacing: 2px;">ALWAFA</h1>
                            <p style="margin:5px 0 0 0; font-size:12px; font-weight:bold; color:#555;">سجل الإجازات الرسمي</p>
                        </div>
                        <div style="text-align: left; font-size:14px;">
                            <strong>تاريخ الطباعة:</strong> ${new Date().toLocaleDateString('en-GB')}
                        </div>
                    </div>

                    <div style="font-size:16px; margin-bottom:20px; background:#f9f9f9; padding:15px; border-radius:8px; border:1px solid #eee;">
                        <p style="margin:0 0 10px 0;"><strong>معيار البحث:</strong> ${searchTerm ? searchTerm : 'تقرير شامل (جميع الموظفين)'}</p>
                        <p style="margin:0;"><strong>إجمالي الإجازات السنوية المستهلكة في هذا التقرير:</strong> <span style="color:#d35400; font-weight:bold; font-size:18px;">${totalAnnual} يوم</span></p>
                    </div>
                    
                    ${tableHtml}
                    
                    <div style="margin-top:50px; display:flex; justify-content:space-between; font-weight:bold;">
                        <div style="text-align:center;">توقيع واعتماد الموارد البشرية<br><br>_________________</div>
                        <div style="text-align:center;">الختم الرسمي<br><br>_________________</div>
                    </div>
                </body>
                </html>
            `;
            
            printWindow.document.write(html);
            printWindow.document.close();
            printWindow.focus();
            
            // إعطاء المتصفح نصف ثانية لرسم الصفحة ثم استدعاء أمر الطباعة آلياً
            setTimeout(() => { 
                printWindow.print(); 
                // اختياري: إغلاق النافذة بعد الطباعة
                // printWindow.close(); 
            }, 500);
        }
        // ==================== توليد نموذج إشعار إجازة سنوية (مادة 109) ====================
        async function generateLeaveNotification(leaveId) {
            const l = allLeavesData.find(x => x.id === leaveId);
            if (!l) return;

            // 1. الفحص القانوني الصارم (30 يوماً على الأقل)
            const startDate = new Date(l.startDate);
            const today = new Date();
            // تصفير الوقت للمقارنة الدقيقة باليوم
            today.setHours(0,0,0,0);
            startDate.setHours(0,0,0,0);

            const diffTime = startDate - today;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            if (diffDays < 30) {
                return alert(`🛑 عذراً، لا يمكن إصدار نموذج التبليغ.\nتاريخ بداية الإجازة متبقي عليه (${diffDays}) يوماً فقط.\nيجب إشعار الموظف قبل 30 يوماً على الأقل لتطبيق المادة 109 من نظام العمل.`);
            }

            const btn = event.currentTarget;
            const originalIcon = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>'; btn.disabled = true;

            // جلب بيانات الموظف للمسمى الوظيفي
            const user = allUsersData.find(u => u.username === l.username);
            const jobTitle = user ? user.jobTitle : 'غير محدد';

            const tempContainer = document.createElement('div');
            tempContainer.style.position = 'absolute'; tempContainer.style.top = '0'; tempContainer.style.left = '0'; 
            tempContainer.style.zIndex = '-9999'; tempContainer.style.opacity = '0'; tempContainer.style.pointerEvents = 'none';

            const headerHtml = `
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom: 3px solid #007f3d; padding-bottom: 15px; margin-bottom: 40px; width: 100%;">
                    <div style="text-align: right; max-width: 60%;">
                        <img src="/logo.png" style="max-height: 85px; max-width: 100%; object-fit: contain;" onerror="this.style.display='none'">
                    </div>
                    <div style="text-align: left;">
                        <h1 style="margin:0; color:#007f3d; font-size: 34px; font-weight:900; letter-spacing: 2px;">ALWAFA</h1>
                        <p style="margin:5px 0 0 0; font-size:14px; font-weight:bold; color:#555;">CR: 1010602654</p>
                    </div>
                </div>
            `;

            const formContent = `
                <table style="width: 100%; border-collapse: collapse; font-size: 15px; margin: 0 auto; margin-bottom:40px;">
                    <tbody>
                        <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; width:30%; color:#555;">اسم الموظف</td><td style="padding:15px; font-weight:bold;">${l.name}</td></tr>
                        <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; color:#555;">الرقم الوظيفي</td><td style="padding:15px; font-weight:bold; color:#d35400;">${l.username}</td></tr>
                        <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; color:#555;">المسمى الوظيفي</td><td style="padding:15px; font-weight:bold;">${jobTitle}</td></tr>
                        <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; color:#555;">تاريخ بداية الإجازة</td><td style="padding:15px; font-weight:bold; color:#2980b9;">${l.startDate}</td></tr>
                        <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; color:#555;">المدة المعتمدة</td><td style="padding:15px; font-weight:bold;">${l.duration} يوماً</td></tr>
                        <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; color:#555;">تاريخ العودة للعمل</td><td style="padding:15px; font-weight:bold; color:#27ae60;">${l.returnDate}</td></tr>
                    </tbody>
                </table>
                <div style="background:#fef5e7; padding:20px; border-right:4px solid #f39c12; font-size:14px; line-height:1.8; text-align:justify; margin-bottom:80px;">
                    <strong>الزميل / الزميلة الموضح بياناته أعلاه،</strong><br><br>
                    نفيدكم بأنه تقرر تمتعكم بإجازتكم السنوية بناءً على <strong>المادة (109) من نظام العمل السعودي</strong>، والتي تنص على حق صاحب العمل في تحديد مواعيد التمتع بالإجازات السنوية وإشعار الموظف بها قبل (30) يوماً على الأقل.<br><br>
                    بناءً عليه، تم تحديد إجازتكم السنوية لتبدأ في التاريخ الموضح أعلاه. نتمنى لكم إجازة سعيدة وعودة سالمة للعمل.
                </div>
                <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 16px;">
                    <div style="text-align:center;">اعتماد إدارة الموارد البشرية<br><br>_________________</div>
                    <div style="text-align:center;">توقيع الموظف بالعلم والاستلام<br><br>_________________<br><br>التاريخ: ___ / ___ / _______ م</div>
                </div>
            `;

            const pageHtml = `
                <div id="leave-notif-print-area" style="width: 800px; height: 1131px; padding: 50px; font-family: 'Segoe UI', Tahoma, sans-serif; direction: rtl; background: white; color: #333; box-sizing: border-box; position: relative; overflow: hidden;">
                    ${headerHtml}
                    <h2 style="text-align:center; color:#333; margin-bottom: 40px; font-size:20px; text-decoration:underline;">نموذج إشعار بإجازة سنوية (مادة 109)</h2>
                    ${formContent}
                    <div style="position: absolute; bottom: 40px; width: calc(100% - 100px); text-align:center; color:#888; font-size:14px; border-top: 1px solid #eee; padding-top: 10px;">أُصدر هذا الإشعار آلياً من نظام الموارد البشرية بتاريخ ${new Date().toLocaleDateString('en-GB')}</div>
                </div>
            `;

            tempContainer.innerHTML = pageHtml;
            document.body.appendChild(tempContainer);

            try {
                const canvasOpt = { scale: 2, useCORS: true, backgroundColor: '#ffffff', windowWidth: 800 };
                const canvas = await html2canvas(document.getElementById('leave-notif-print-area'), canvasOpt);
                const link = document.createElement('a');
                link.download = `Leave_Notification_${l.username}.jpg`;
                link.href = canvas.toDataURL('image/jpeg', 0.95);
                link.click();

                document.body.removeChild(tempContainer);
            } catch (error) {
                console.error("خطأ:", error);
                alert("حدث خطأ أثناء معالجة النموذج.");
                if(document.body.contains(tempContainer)) document.body.removeChild(tempContainer);
            }
            
            btn.innerHTML = originalIcon; 
            btn.disabled = false;
        }

        // --- محرك رفع الإكسيل السحري ---
        function processExcelLeaves(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = async function(e) {
                const data = new Uint8Array(e.target.result);
                const workbook = XLSX.read(data, {type: 'array'});
                const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                
                // تحويل الإكسيل إلى مصفوفة (بافتراض العناوين في الصف الأول)
                const excelRows = XLSX.utils.sheet_to_json(firstSheet, {raw: false}); 
                
                if(excelRows.length === 0) return alert("الملف فارغ!");

                let preparedLeaves = [];
                // نفترض أن العناوين في الإكسيل هي: "رقم الموظف", "المدة", "تاريخ البدء", "نوع الاجازة"
                excelRows.forEach(row => {
                    const empId = row['رقم الموظف'];
                    const duration = parseInt(row['المدة']);
                    const rawStart = row['تاريخ البدء']; // SheetJS usually returns MM/DD/YYYY or similar if raw:false
                    const type = row['نوع الاجازة'] || 'سنوية';

                    if(empId && duration && rawStart) {
                        // محاولة تنظيف التاريخ ليكون YYYY-MM-DD
                        let startDate = new Date(rawStart);
                        if(!isNaN(startDate)) {
                            let startStr = startDate.toISOString().split('T')[0];
                            
                            // حساب الانتهاء والعودة آلياً
                            let endD = new Date(startDate); endD.setDate(endD.getDate() + duration - 1);
                            let retD = new Date(endD); retD.setDate(retD.getDate() + 1);

                            preparedLeaves.push({
                                username: empId.toString(),
                                type: type,
                                startDate: startStr,
                                duration: duration,
                                endDate: endD.toISOString().split('T')[0],
                                returnDate: retD.toISOString().split('T')[0]
                            });
                        }
                    }
                });

                if(preparedLeaves.length === 0) return alert("لم يتم العثور على بيانات صحيحة. تأكد من أسماء الأعمدة.");

                if(confirm(`تم العثور على ${preparedLeaves.length} إجازة. هل تريد رفعها واعتمادها في النظام والتحضير؟`)) {
                    await fetch('/api/leaves-bulk', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({leaves: preparedLeaves}) });
                    alert('تم رفع الإجازات وحقنها في التحضير بنجاح! ✅');
                    loadLeavesData();
                }
                event.target.value = ''; // تفريغ الملف
            };
            reader.readAsArrayBuffer(file);
        }
        // دوال الرقابة
        let fullAuditLog = [];
        async function openAuditLog() {
            const views = ['home', 'forms', 'policies', 'team', 'announcements', 'admin-usage', 'admin-requests', 'admin-settings', 'admin-users', 'manager-attendance', 'admin-attendance', 'hr-dashboard', 'admin-leaves', 'admin-audit'];
            views.forEach(v => { const el = document.getElementById(v + '-view'); if (el) el.style.display = 'none'; });
            document.getElementById('admin-audit-view').style.display = 'block';
            document.getElementById('page-title').innerText = 'سجل التدقيق والرقابة';
            
            try {
                fullAuditLog = await (await fetch('/api/audit-log')).json();
                renderAuditLog(fullAuditLog);
            } catch(e) {}
        }

        function renderAuditLog(data) {
            const tbody = document.getElementById('audit-table-body');
            if(data.length === 0) return tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">لا توجد سجلات بعد.</td></tr>';
            tbody.innerHTML = data.map(log => `<tr><td style="direction:ltr; text-align:right; font-size:11px;">${log.timestamp}</td><td style="font-weight:bold; color:#c0392b;">${log.actor}</td><td><span style="background:#eee; padding:3px 8px; border-radius:12px; font-size:11px;">${log.action}</span></td><td style="font-weight:bold;">${log.target}</td><td style="font-size:12px; color:#555;">${log.details}</td></tr>`).join('');
        }
        function filterAuditLog() {
            const q = document.getElementById('audit-search').value.toLowerCase();
            renderAuditLog(fullAuditLog.filter(l => l.target.toLowerCase().includes(q) || l.actor.toLowerCase().includes(q) || l.action.toLowerCase().includes(q)));
        }
        // دالة نداء محرك حساب الإجازات
        async function recalculateAllLeaves() {
            if(!confirm("سيقوم النظام الآن بقراءة تواريخ مباشرة جميع الموظفين، وحساب أرصدتهم المستحقة حتى تاريخ اليوم، وخصم إجازاتهم السابقة.\nهل أنت متأكد من البدء؟")) return;

            const btn = document.getElementById('btn-recalc-leaves');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري معالجة البيانات والعمليات الحسابية...';
            btn.disabled = true;
            btn.style.background = '#ccc';

            try {
                const res = await (await fetch('/api/recalculate-leaves', { 
                    method: 'POST', 
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ byUser: globalEmpName })
                })).json();

                if(res.success) {
                    alert(`✅ تمت العملية بنجاح!\nتم تحديث أرصدة ${res.count} موظف بدقة عالية.`);
                    loadAdminUsers(); // تحديث الجدول في الخلفية
                } else {
                    alert("❌ فشل التحديث: " + res.message);
                }
            } catch (e) {
                alert("حدث خطأ بالاتصال بالسيرفر.");
            }

            btn.innerHTML = originalText;
            btn.disabled = false;
            btn.style.background = '#d35400';
        }
        let currentEOSReport = null;

        function openEosModal() {
            document.getElementById('eos-input-area').style.display = 'block';
            document.getElementById('eos-report-area').style.display = 'none';
            document.querySelectorAll('#eos-input-area input').forEach(i => i.value = '');
            if(document.getElementById('eos-rehire')) document.getElementById('eos-rehire').checked = true;
            document.getElementById('eos-modal').style.display = 'flex';
        }
        function quickEosModal(username, name) {
            document.getElementById('eos-input-area').style.display = 'block';
            document.getElementById('eos-report-area').style.display = 'none';
            document.querySelectorAll('#eos-input-area input').forEach(i => i.value = '');
            
            // تعبئة البيانات آلياً
            document.getElementById('eos-username').value = username;
            document.getElementById('eos-name').value = name;
            
            if(document.getElementById('eos-rehire')) document.getElementById('eos-rehire').checked = true;
            document.getElementById('eos-modal').style.display = 'flex';
        }

        function fetchEosEmpName() {
            const username = document.getElementById('eos-username').value.trim();
            const user = allUsersData.find(u => u.username === username);
            document.getElementById('eos-name').value = user ? user.name : 'موظف غير موجود!';
        }

        // ==================== دوال إنهاء الخدمة (متصلة بنقل العهدة) ====================

        async function submitEOS() {
            const payload = {
                username: document.getElementById('eos-username').value.trim(),
                lastWorkingDay: document.getElementById('eos-last-day').value,
                termType: document.getElementById('eos-type').value,
                termReason: document.getElementById('eos-reason').value.trim(),
                byUser: globalEmpName
            };

            if(!payload.username || !payload.lastWorkingDay || !document.getElementById('eos-name').value) {
                return alert("يرجى إدخال الرقم الوظيفي وتاريخ آخر يوم عمل بشكل صحيح.");
            }

            // 🔥 الفحص الأمني: هل هذا الموظف مدير ولديه فريق؟
            const checkRes = await fetch('/api/check-dependents', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({username: payload.username})});
            const check = await checkRes.json();

            // إذا كان مديراً، يتم اعتراض العملية وفتح نافذة نقل العهدة
            if (check.hasDependents) {
                pendingAction = { type: 'eos', payload: payload };
                document.getElementById('transfer-message').innerHTML = `هذا الموظف مسؤول عن <strong>${check.employeeCount} موظف</strong>.<br>الرجاء اختيار بديل لنقل العهدة قبل الإنهاء.`;
                populateManagersDropdown('', 't-manager', check.managerName); 
                
                document.getElementById('eos-modal').style.display = 'none'; // إخفاء نافذة الإنهاء
                document.getElementById('transfer-modal').style.display = 'flex'; // إظهار نافذة نقل العهدة
                return; // إيقاف التنفيذ هنا
            }

            // إذا لم يكن مديراً، نكمل الإجراء الطبيعي الذي برمجته أنت
            if(confirm(`⚠️ تحذير نهائي:\nهل أنت متأكد من إنهاء خدمات الموظف في تاريخ ${payload.lastWorkingDay}؟\nسيتم إيقاف حسابه، إغلاق طلباته، وتسوية تحضيره آلياً.`)) {
                await runEOSFetch(payload);
            }
        }

        // دالة مساعدة لتنفيذ الإنهاء (تعمل مع الموظف العادي ومع المدير بعد نقل عهدته)
        async function runEOSFetch(payload) {
            const res = await (await fetch('/api/terminate-employee', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload) })).json();
            
            if(res.success) {
                alert("✅ تم إنهاء الخدمة بنجاح، وتوليد التقرير المالي للكميات.");
                currentEOSReport = res.report;
                
                // تعبئة التقرير في الشاشة
                document.getElementById('r-empId').innerText = currentEOSReport.empId;
                document.getElementById('r-name').innerText = currentEOSReport.name;
                document.getElementById('r-idNumber').innerText = currentEOSReport.idNumber;
                document.getElementById('r-join').innerText = currentEOSReport.joinDate;
                document.getElementById('r-leave').innerText = currentEOSReport.lastWorkingDay;
                document.getElementById('r-duration').innerText = currentEOSReport.serviceDuration;
                document.getElementById('r-deserves').innerText = currentEOSReport.deservesEOS;
                document.getElementById('r-salary').innerText = currentEOSReport.totalSalary;
                document.getElementById('r-gosiFee').innerText = currentEOSReport.gosiFeeMonth;
                document.getElementById('r-currDays').innerText = currentEOSReport.currentMonthPayableDays;
                document.getElementById('r-prevDays').innerText = currentEOSReport.prevMonthDeductDays;
                document.getElementById('r-gosiAdj').innerText = currentEOSReport.gosiDaysAdjustment;
                document.getElementById('r-leaveBal').innerText = currentEOSReport.leaveBalance;
                document.getElementById('r-baladiyah').innerText = currentEOSReport.baladiyahFee;

                document.getElementById('eos-input-area').style.display = 'none';
                document.getElementById('eos-report-area').style.display = 'block';
                document.getElementById('eos-modal').style.display = 'flex'; // تأكيد ظهور الشاشة
                
                loadAdminUsers(); // تحديث الجدول لإظهاره كموقوف
            } else {
                alert("❌ خطأ: " + res.message);
            }
        }

        function exportEOSToExcel() {
            if(!currentEOSReport) return;
            const r = currentEOSReport;
            const csvContent = "\uFEFF" + 
                "الرقم الوظيفي,الاسم,رقم الهوية,تاريخ الانضمام,تاريخ آخر يوم عمل,مدة الخدمة,استحقاق المكافأة,الراتب الإجمالي,رسوم التأمينات الشهرية,أيام عمل مستحقة,أيام خصم غياب,أيام تأمينات مستردة/مخصومة,رصيد الإجازة المتبقي,رسوم كرت البلدية\n" +
                `"${r.empId}","${r.name}","${r.idNumber}","${r.joinDate}","${r.lastWorkingDay}","${r.serviceDuration}","${r.deservesEOS}","${r.totalSalary}","${r.gosiFeeMonth}","${r.currentMonthPayableDays}","${r.prevMonthDeductDays}","${r.gosiDaysAdjustment}","${r.leaveBalance}","${r.baladiyahFee}"`;
            
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = `تصفية_كميات_${r.empId}.csv`;
            link.click();
        }
        
    </script>
</body>
</html>
