                            <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; color:#555;">رقم الهوية</td><td style="padding:15px; font-weight:bold;">${user.idNumber || '-'}</td></tr>
                            <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; color:#555;">المسمى الوظيفي</td><td style="padding:15px; font-weight:bold;">${user.jobTitle || '-'}</td></tr>
                            <tr style="border-bottom: 1px solid #eee;"><td style="padding:15px; font-weight:bold; background:#f9f9f9; color:#555;">الرئيس المباشر</td><td style="padding:15px; font-weight:bold;">${user.directManager || '________________'}</td></tr>
