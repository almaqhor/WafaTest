                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">الميلاد (هجري)</td><td style="padding:12px; font-weight:bold; color:#000;">${birthH}</td>
                            </tr>
                            
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">رقم الجوال</td><td style="padding:12px; font-weight:bold; color:#000;">${user.phone || '________________'}</td>
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">العنوان الوطني</td><td style="padding:12px; font-weight:bold; color:#000;">${natAddress}</td>
                            </tr>
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">المدينة</td><td style="padding:12px; font-weight:bold; color:#000;">${user.city || '________________'}</td>
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">المنطقة</td><td style="padding:12px; font-weight:bold; color:#000;">${user.region || '________________'}</td>
                            </tr>
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">الإيميل</td><td style="padding:12px; font-weight:bold; color:#000;" colspan="3">${user.email || '________________________________________________'}</td>
                            </tr>
                            
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">اسم البنك</td><td style="padding:12px; font-weight:bold; color:#000;">${user.bankName || '________________'}</td>
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">رقم الآيبان</td><td style="padding:12px; font-weight:bold; color:#000; direction:ltr; text-align:right;">${empIban !== '________________' ? (empIban.toUpperCase().startsWith('SA') ? empIban : 'SA ' + empIban) : 'SA __________________'}</td>
                            </tr>
                            <tr style="border-bottom: 1px solid #eee;"><td colspan="4" style="background:#e8f8f5; padding:8px; text-align:center; font-weight:bold; color:#007f3d;">بيانات الطوارئ</td></tr>
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">اسم الطوارئ</td><td style="padding:12px; font-weight:bold; color:#000;">${user.emergencyName || '________________'}</td>
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">رقم الطوارئ</td><td style="padding:12px; font-weight:bold; color:#000;">${emergPhone}</td>
                            </tr>
                            <tr style="border-bottom: 1px solid #eee;"><td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">صلة القرابة</td><td style="padding:12px; font-weight:bold; color:#000;" colspan="3">${user.emergencyRelation || '________________'}</td></tr>
                        </tbody>
                    </table>
                    <div style="text-align: left; font-weight: bold; font-size: 16px; padding-left: 50px;">
