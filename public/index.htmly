                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555;">رقم الهوية</td><td style="padding:12px; font-weight:bold; color:#000;">${user.idNumber || '________________'}</td>
                                <td style="padding:12px; font-weight:bold; background:#f9f9f9; color:#555; width:20%;">انتهاء الهوية</td><td style="padding:12px; font-weight:bold; color:#000;">${user.idExpiry || '________________'}</td>
